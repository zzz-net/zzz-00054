{
  "rule_version": "1.0.1",
  "dedup_window_seconds": 60,
  "severity_mapping": {
    "debug": "DEBUG",
    "DEBUG": "DEBUG",
    "info": "INFO",
    "INFO": "INFO",
    "notice": "INFO",
    "NOTICE": "INFO",
    "warning": "WARNING",
    "WARN": "WARNING",
    "WARNING": "WARNING",
    "warn": "WARNING",
    "error": "ERROR",
    "ERROR": "ERROR",
    "err": "ERROR",
    "ERR": "ERROR",
    "critical": "CRITICAL",
    "CRITICAL": "CRITICAL",
    "CRIT": "CRITICAL",
    "fatal": "FATAL",
    "FATAL": "FATAL",
    "P1": "CRITICAL",
    "P2": "ERROR",
    "P3": "WARNING",
    "P4": "INFO",
    "P5": "DEBUG"
  },
  "timestamp_formats": [
    "%Y-%m-%d %H:%M:%S",
    "%Y-%m-%dT%H:%M:%S",
    "%Y-%m-%dT%H:%M:%S.%f",
    "%Y/%m/%d %H:%M:%S",
    "%Y-%m-%d %H:%M:%S.%f",
    "%d/%b/%Y:%H:%M:%S %z",
    "%Y-%m-%d %H:%M:%S,%f"
  ],
  "gap_threshold_seconds": 30,
  "phases": [],
  "source_priority": {
    "alert": 0,
    "note": 1,
    "log": 2
  },
  "dedup_similarity_threshold": 0.8,
  "include_source_in_dedup": true,
  "log_line_pattern": "^(?P<timestamp>\\S+(?:\\s+\\S+)?)\\s+(?P<severity>[A-Z]+)\\s+(?P<message>.*)$",
  "csv_time_column": "timestamp",
  "csv_message_column": "message",
  "csv_severity_column": "severity"
}